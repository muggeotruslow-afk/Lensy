{
  "name": "lensy",
  "version": "0.1.1",
  "description": "Lensy — 框选屏幕翻译 + 单词查询 + Anki 生词本，Claude 风格暖色 UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "keywords": ["ocr", "translation", "electron", "deepseek", "tesseract", "anki", "vocabulary", "screenshot-translator"],
  "author": "muggeotruslow-afk",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "jimp": "^1.6.1",
    "openai": "^6.39.1",
    "tesseract.js": "^7.0.0"
  },
  "build": {
    "appId": "com.muggeotruslow-afk.lensy",
    "productName": "Lensy",
    "files": [
      "main.js",
      "overlay.html",
      "result.html",
      "settings.html",
      "vocab.html",
      "quick.html",
      "theme.css",
      "ocr.ps1",
      "package.json",
      "assets/icon.png",
      "assets/icon.ico",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "ocr.ps1", "to": "ocr.ps1" },
      { "from": "assets/tessdata", "to": "tessdata" }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Lensy"
    },
    "directories": {
      "output": "dist"
    }
  }
}
